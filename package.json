{
  "name": "@amreraky/react-infinite-scroller",
  "version": "2.0.0",
  "description": "Infinite scroll component for React in ES6",
  "keywords": [
    "infinite",
    "scroll",
    "react"
  ],
  "homepage": "https://github.com/amribrahim1/react-infinite-scroller#readme",
  "bugs": {
    "url": "https://github.com/amribrahim1/react-infinite-scroller/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/amribrahim1/react-infinite-scroller.git"
  },
  "license": "MIT",
  "author": "Amr Eraky <amribrahim11@gmail.com>",
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "build": "mkdirp dist && babel src/InfiniteScroll.js --out-file dist/InfiniteScroll.js",
    "prepublish": "npm run build",
    "test": "nyc npm run spec",
    "spec": "_mocha -R spec ./test/test_helper.js --recursive test/*_test.js",
    "lint": "eslint ./src ./test",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "prop-types": "^15.5.8"
  },
  "devDependencies": {
    "@testing-library/react": "^13.0.1",
    "babel-cli": "^6.6.5",
    "babel-core": "^6.26.3",
    "babel-eslint": "^7.2.3",
    "babel-istanbul": "^0.12.2",
    "babel-plugin-add-module-exports": "^0.1.2",
    "babel-plugin-istanbul": "^4.1.6",
    "babel-plugin-transform-object-rest-spread": "^6.23.0",
    "babel-preset-es2015": "^6.6.0",
    "babel-preset-react": "^6.5.0",
    "babel-preset-stage-2": "^6.13.0",
    "chai": "^3.5.0",
    "eslint": "^4.10.0",
    "eslint-config-last": "^0.0.3",
    "eslint-config-prettier": "^2.6.0",
    "eslint-plugin-prettier": "^2.3.1",
    "eslint-plugin-react": "^7.4.0",
    "husky": "^0.14.3",
    "istanbul": "^0.4.5",
    "jsdom": "^10.0.0",
    "lint-staged": "^4.3.0",
    "mkdirp": "^0.5.1",
    "mocha": "^3.3.0",
    "nyc": "^15.1.0",
    "prettier": "^1.7.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sinon": "^2.1.0"
  },
  "peerDependencies": {
    "react": ">=16.0.0"
  },
  "jsnext:main": "src/InfiniteScroll.js",
  "lint-staged": {
    "*.{js,jsx}": [
      "node_modules/.bin/eslint --fix --max-warnings 0",
      "git add"
    ]
  }
}