  },
  "dependencies": {
    "prop-types": "^15.5.8"
  },
  "devDependencies": {
    "@testing-library/react": "^13.0.1",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@types/chai": "^4.3.11",
    "@types/jsdom": "^21.1.3",
    "@types/mocha": "^10.0.6",
    "@types/sinon": "^10.0.17",
    "chai": "^3.5.0",
    "eslint": "^4.10.0",
    "eslint-config-prettier": "^2.6.0",
    "eslint-plugin-prettier": "^2.3.1",
    "eslint-plugin-react": "^7.4.0",
    "husky": "^0.14.3",
    "jsdom": "^10.0.0",
    "lint-staged": "^4.3.0",
    "mocha": "^3.3.0",
    "nyc": "^15.1.0",
    "prettier": "^1.7.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sinon": "^2.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": ">=16.0.0"
